# Optional remote alert delivery. Keep real values in your Windows user environment, never in Git.
SENTINELSHIELD_ALERT_COOLDOWN_SECONDS=120
SENTINELSHIELD_SMTP_HOST=smtp.example.com
SENTINELSHIELD_SMTP_PORT=587
SENTINELSHIELD_SMTP_TLS=true
SENTINELSHIELD_SMTP_USER=alerts@example.com
SENTINELSHIELD_SMTP_PASSWORD=app-password
SENTINELSHIELD_SMTP_FROM=alerts@example.com
SENTINELSHIELD_ALERT_EMAIL_TO=security@example.com
SENTINELSHIELD_TELEGRAM_BOT_TOKEN=123456:bot-token
SENTINELSHIELD_TELEGRAM_CHAT_ID=123456789
SENTINELSHIELD_TWILIO_ACCOUNT_SID=ACxxxxxxxx
SENTINELSHIELD_TWILIO_AUTH_TOKEN=token
SENTINELSHIELD_TWILIO_FROM=+15551234567
SENTINELSHIELD_SMS_TO=+15557654321
